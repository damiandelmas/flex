#!/usr/bin/env python3
"""Throwaway CLI shim. Plan 4 replaces this with the real thing."""
import sys, sqlite3, os, json

if len(sys.argv) < 3:
    print("Usage: flex <cell> <sql>", file=sys.stderr)
    sys.exit(1)

cell, query = sys.argv[1], sys.argv[2]
db_path = os.path.expanduser(f"~/.qmem/cells/projects/{cell}/main.db")
if not os.path.exists(db_path):
    print(f"Cell not found: {db_path}", file=sys.stderr)
    sys.exit(1)

db = sqlite3.connect(db_path)
db.row_factory = sqlite3.Row
rows = [dict(r) for r in db.execute(query).fetchall()]
print(json.dumps(rows, indent=2, default=str))
