# Dirty upgrade test — simulates upgrade from 0.1.43 to current.
#
# Installs the old PyPI version first, then overlays local source.
# Tests that flex init, search, sync all work on top of old data.
#
# Build:
#   docker build -f tests/docker/Dockerfile.dirty-upgrade -t flex-test-dirty-upgrade .
#
# Run:
#   docker run --rm flex-test-dirty-upgrade

FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv python3.12-dev \
    git jq build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install old version first
RUN pip install getflex==0.1.43 --break-system-packages

# Now copy and install new version on top
COPY pyproject.toml /flex/
COPY flex/ /flex/flex/
WORKDIR /flex

RUN pip install -e ".[mcp,cluster]" --break-system-packages

COPY tests/docker/seed_sessions.py /seed_sessions.py
COPY tests/docker/harness.py /harness.py
COPY tests/docker/run_dirty.py /run_dirty.py
RUN NUM_SESSIONS=20 python3 /seed_sessions.py

CMD ["python3", "/run_dirty.py", "--scenario", "upgrade"]
