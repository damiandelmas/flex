# Dirty minimal test — no jq, no git.
#
# Verifies that flex init fails gracefully with a clear error message
# when required system dependencies are missing.
#
# Build:
#   docker build -f tests/docker/Dockerfile.dirty-minimal -t flex-test-dirty-minimal .
#
# Run:
#   docker run --rm flex-test-dirty-minimal

FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv python3.12-dev \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Deliberately NO git, NO jq
COPY pyproject.toml /flex/
COPY flex/ /flex/flex/
WORKDIR /flex

RUN pip install -e ".[mcp,cluster]" --break-system-packages

COPY tests/docker/harness.py /harness.py
COPY tests/docker/run_dirty.py /run_dirty.py

CMD ["python3", "/run_dirty.py", "--scenario", "minimal"]
